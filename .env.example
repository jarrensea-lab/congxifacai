# DeepSeek API 配置
DEEPSEEK_API_KEY=

# Qwen (通义千问) API 配置 — 多模型多样性（裁判用）
# 获取方式: https://bailian.console.aliyun.com/ → API-KEY 管理
QWEN_API_KEY=

# Tushare 数据源
TUSHARE_TOKEN=
CONGXI_TUSHARE_NEWS_ROOT=/Users/zhuchenyuan/AI/projects/司库/01-资料采集/量化投资/Serenity研究/数据采集/tushare-news

# 飞书机器人
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_ONLY=true

# 报告归档
CONGXI_REPORT_ARCHIVE_DIR=/Users/zhuchenyuan/AI/projects/司库/01-资料采集/量化投资/恭喜发财报告

# 投资策略模式: capital_preservation / growth_sprint
CONGXI_STRATEGY_MODE=growth_sprint

# 飞书多维表格配置 — 6张维度的table_id
# 当前默认只走 Webhook，以下 API 通道暂不启用。
