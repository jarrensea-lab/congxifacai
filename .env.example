FEISHU_TABLE_STRATEGY=
FEISHU_TABLE_STOCK_POOL=
FEISHU_TABLE_POSITIONS=
FEISHU_TABLE_INDICES=
FEISHU_TABLE_RISK=
FEISHU_TABLE_PERFORMANCE=

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
FRONTEND_PORT=3000
